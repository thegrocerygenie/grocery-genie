# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Resend audience (waitlist) — https://resend.com/audiences
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000

# Optional: send a welcome email when someone joins.
# Leave WAITLIST_FROM blank to skip the welcome send.
# Must be a verified Resend sending address (https://resend.com/domains).
# WAITLIST_FROM=Grocery Genie <hello@grocerygenie.app>
# WAITLIST_WELCOME_SUBJECT=You're on the Grocery Genie list
# WAITLIST_WELCOME_TEXT=Custom welcome copy. Leave unset to use the default.

# Optional: lock CORS to your production origin (defaults to *)
# ALLOWED_ORIGIN=https://grocerygenie.app

# Local dev only
PORT=3000
